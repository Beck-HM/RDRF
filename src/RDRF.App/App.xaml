<Application x:Class="RDRF.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ============================================================
                 THEME COLORS — Modern dark with purple accent
                 ============================================================ -->

            <!-- Backgrounds (darkest → lightest) -->
            <Color x:Key="BackgroundColor">#FF0A0A0B</Color>
            <Color x:Key="SurfaceColor">#FF111113</Color>
            <Color x:Key="SurfaceHoverColor">#FF1A1A1E</Color>
            <Color x:Key="ElevatedSurfaceColor">#FF1C1C21</Color>
            <Color x:Key="InputBackgroundColor">#FF16161A</Color>
            <Color x:Key="InputFocusedBackgroundColor">#FF1E1E24</Color>

            <!-- Borders -->
            <Color x:Key="BorderColor">#FF2A2A30</Color>
            <Color x:Key="BorderHoverColor">#FF3A3A42</Color>
            <Color x:Key="BorderFocusColor">#FF7C6BF2</Color>

            <!-- Accent (Purple) -->
            <Color x:Key="AccentColor">#FF7C6BF2</Color>
            <Color x:Key="AccentHoverColor">#FF8E80F5</Color>
            <Color x:Key="AccentPressedColor">#FF6A57E8</Color>
            <Color x:Key="AccentSubtleColor">#207C6BF2</Color>
            <Color x:Key="AccentGlowColor">#407C6BF2</Color>

            <!-- Text -->
            <Color x:Key="TextPrimaryColor">#FFF0F0F0</Color>
            <Color x:Key="TextSecondaryColor">#FF9CA3AF</Color>
            <Color x:Key="TextTertiaryColor">#FF6B7280</Color>
            <Color x:Key="TextOnAccentColor">#FFFFFFFF</Color>

            <!-- Status Colors -->
            <Color x:Key="SuccessColor">#FF34D399</Color>
            <Color x:Key="WarningColor">#FFFBBF24</Color>
            <Color x:Key="ErrorColor">#FFF87171</Color>
            <Color x:Key="InfoColor">#FF60A5FA</Color>

            <!-- ============================================================
                 SOLID COLOR BRUSHES
                 ============================================================ -->
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
            <SolidColorBrush x:Key="ElevatedSurfaceBrush" Color="{StaticResource ElevatedSurfaceColor}" />
            <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
            <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}" />
            <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
            <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
            <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}" />
            <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
            <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}" />
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
            <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
            <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

            <!-- Legacy aliases (keep old names working) -->
            <SolidColorBrush x:Key="SurfaceHighlightBrush" Color="{StaticResource SurfaceHoverColor}" />

            <!-- ============================================================
                 DROP SHADOWS
                 ============================================================ -->
            <DropShadowEffect x:Key="CardShadow"
                              BlurRadius="24" ShadowDepth="0"
                              Color="#000000" Opacity="0.25" Direction="270" />
            <DropShadowEffect x:Key="CardHoverShadow"
                              BlurRadius="32" ShadowDepth="0"
                              Color="#000000" Opacity="0.4" Direction="270" />
            <DropShadowEffect x:Key="ElevatedShadow"
                              BlurRadius="40" ShadowDepth="0"
                              Color="#000000" Opacity="0.5" Direction="270" />
            <DropShadowEffect x:Key="AccentGlowShadow"
                              BlurRadius="20" ShadowDepth="0"
                              Color="#7C6BF2" Opacity="0.25" Direction="270" />

            <!-- ============================================================
                 FONT SIZES
                 ============================================================ -->
            <sys:Double x:Key="FontSizeSmall">12</sys:Double>
            <sys:Double x:Key="FontSizeNormal">14</sys:Double>
            <sys:Double x:Key="FontSizeLarge">16</sys:Double>
            <sys:Double x:Key="FontSizeXLarge">20</sys:Double>
            <sys:Double x:Key="FontSizeTitle">28</sys:Double>

            <!-- ============================================================
                 CORNER RADII
                 ============================================================ -->
            <CornerRadius x:Key="CornerRadiusSmall">4</CornerRadius>
            <CornerRadius x:Key="CornerRadiusNormal">8</CornerRadius>
            <CornerRadius x:Key="CornerRadiusLarge">12</CornerRadius>

            <!-- ============================================================
                 CUSTOM SCROLLBAR — Minimal flat style
                 ============================================================ -->
            <Style x:Key="FlatScrollBarThumb" TargetType="Thumb">
                <Setter Property="Background" Value="#4A4A5C" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="MinWidth" Value="6" />
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="3" Margin="1" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border Background="Transparent">
                                <Track x:Name="PART_Track"
                                       ViewportSize="{TemplateBinding ViewportSize}"
                                       Minimum="{TemplateBinding Minimum}"
                                       Maximum="{TemplateBinding Maximum}"
                                       Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Mode=TwoWay}"
                                       Orientation="{TemplateBinding Orientation}">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource FlatScrollBarThumb}" />
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollViewer">
                <Setter Property="BorderThickness" Value="0" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
