<UserControl x:Class="RDRF.App.Controls.SideBySideDiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header row -->
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="#2A2A3C" BorderThickness="0,0,1,1"
                Background="#1A1A2E" Padding="4,3 6,3">
            <TextBlock Text="#" Foreground="#888" FontSize="11"
                       FontFamily="Consolas" HorizontalAlignment="Right" />
        </Border>
        <Border Grid.Row="0" Grid.Column="1" BorderBrush="#2A2A3C" BorderThickness="0,0,1,1"
                Background="#1A1A2E" Padding="8,3">
            <TextBlock Text="Old" Foreground="#AAA" FontSize="11"
                       FontFamily="Consolas" />
        </Border>
        <Border Grid.Row="0" Grid.Column="2" BorderBrush="#2A2A3C" BorderThickness="0,0,0,1"
                Background="#1A1A2E" Padding="8,3">
            <TextBlock Text="New" Foreground="#AAA" FontSize="11"
                       FontFamily="Consolas" />
        </Border>

        <!-- Body -->
        <ScrollViewer x:Name="BodyScroll" Grid.Row="1" Grid.ColumnSpan="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      ScrollChanged="OnScrollChanged">
            <ItemsControl x:Name="DiffItems" Background="Transparent"
                          BorderThickness="0" Focusable="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#1E1E30" BorderThickness="0,0,0,1" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Line numbers -->
                                <Border Grid.Column="0" Background="#16162A"
                                        BorderBrush="#2A2A3C" BorderThickness="0,0,1,0"
                                        Padding="4,2 8,2" MinWidth="80">
                                    <TextBlock Text="{Binding LineNumbers}"
                                               FontFamily="Consolas" FontSize="12"
                                               Foreground="#666"
                                               HorizontalAlignment="Right" />
                                </Border>

                                <!-- Old side -->
                                <Border Grid.Column="1"
                                        Background="{Binding OldBackground}"
                                        BorderBrush="#2A2A3C" BorderThickness="0,0,1,0"
                                        Padding="8,2">
                                    <TextBlock Text="{Binding OldLine}"
                                               Foreground="{Binding OldForeground}"
                                               FontFamily="Consolas" FontSize="12"
                                               TextWrapping="NoWrap" />
                                </Border>

                                <!-- New side -->
                                <Border Grid.Column="2"
                                        Background="{Binding NewBackground}"
                                        Padding="8,2">
                                    <TextBlock Text="{Binding NewLine}"
                                               Foreground="{Binding NewForeground}"
                                               FontFamily="Consolas" FontSize="12"
                                               TextWrapping="NoWrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
