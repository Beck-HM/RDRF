<Window x:Class="RDRF.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RDRF.App"
        mc:Ignorable="d"
        Title="RDRF"
        Height="760"
        Width="980"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Toggle Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="32,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SurfaceHighlightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceHighlightBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <!-- Strategy Card Style -->
        <Style x:Key="StrategyCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="StrategyCardActiveStyle" TargetType="Border" BasedOn="{StaticResource StrategyCardStyle}">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#2A2A40" />
        </Style>

        <Style x:Key="FsaToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="6,2">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          Margin="0,-2,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder"
            Background="{StaticResource BackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo & Title -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <Ellipse Width="10"
                             Height="10"
                             Fill="{StaticResource AccentBrush}"
                             Margin="0,0,8,0" />
                    <TextBlock Text="RDRF"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Tab Buttons -->
                <Border Grid.Column="1"
                        Background="{StaticResource BackgroundBrush}"
                        CornerRadius="8"
                        Padding="4"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="TabEncrypt"
                                Content="Encrypt"
                                Style="{StaticResource TabButtonActiveStyle}"
                                Click="TabEncrypt_Click"
                                Margin="0,0,2,0" />
                        <Button x:Name="TabDecrypt"
                                Content="Decrypt"
                                Style="{StaticResource TabButtonStyle}"
                                Click="TabDecrypt_Click"
                                Margin="2,0,2,0" />
                        <Button x:Name="TabHistory"
                                Content="History"
                                Style="{StaticResource TabButtonStyle}"
                                Click="TabHistory_Click"
                                Margin="2,0,0,0" />
                    </StackPanel>
                </Border>

                <!-- Window Controls -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button x:Name="MinimizeButton"
                            Content="─"
                            Width="46"
                            Height="32"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            BorderThickness="0"
                            Click="MinimizeButton_Click"
                            Cursor="Hand"
                            FontSize="12" />
                    <Button x:Name="MaximizeButton"
                            Content="▢"
                            Width="46"
                            Height="32"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            BorderThickness="0"
                            Click="MaximizeButton_Click"
                            Cursor="Hand"
                            FontSize="10" />
                    <Button x:Name="CloseButton"
                            Content="✕"
                            Width="46"
                            Height="32"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            BorderThickness="0"
                            Click="CloseButton_Click"
                            Cursor="Hand"
                            FontSize="12" />
                </StackPanel>
            </Grid>

            <!-- Divider -->
            <Grid Grid.Row="1"
                  Background="{StaticResource BorderBrush}" />

            <!-- Main Content -->
            <Grid Grid.Row="2"
                  Margin="24">

                <!-- ============== ENCRYPT PAGE ============== -->
                <Grid x:Name="EncryptPage"
                      AllowDrop="True"
                      DragEnter="EncryptPage_DragEnter"
                      DragLeave="EncryptPage_DragLeave"
                      Drop="EncryptPage_Drop">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- File Selection -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="File to Encrypt"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="EncryptFilePath"
                                                  Style="{StaticResource TextBoxStyle}"
                                                  Text="{Binding FilePathDisplay, FallbackValue='No file selected...'}"
                                                  IsReadOnly="True" />

                                        <Button Grid.Column="1"
                                                Content="Browse"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="EncryptBrowse_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- FSS Strategy Selection -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16">
                                 <StackPanel>
                                     <Grid Margin="0,0,0,4">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="Auto" />
                                         </Grid.ColumnDefinitions>
                                         <TextBlock Text="Recovery Strategy"
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextPrimaryBrush}" />
                                         <ToggleButton x:Name="FsaToggle"
                                                       Grid.Column="1"
                                                       Content="FSA"
                                                       FontSize="12"
                                                       Width="48"
                                                       Height="24"
                                                       IsChecked="False"
                                                       Click="FsaToggle_Click"
                                                       Style="{StaticResource FsaToggleStyle}" />
                                     </Grid>
                                    <TextBlock Text="Choose a fragmentation and recovery strategy"
                                               FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,16" />

                                    <!-- Strategy Grid -->
                                    <UniformGrid Columns="4"
                                                 Rows="2">
                                        <!-- FSS-1 -->
                                        <Border x:Name="StrategyFSS1"
                                                Style="{StaticResource StrategyCardActiveStyle}"
                                                Margin="0,0,8,8"
                                                MouseLeftButtonDown="StrategyFSS1_Click">
                                            <StackPanel>
                                                <TextBlock Text="FSS-1"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="Neighbor"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,2" />
                                                <TextBlock Text="~100% overhead"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- FSS-2 -->
                                        <Border x:Name="StrategyFSS2"
                                                Style="{StaticResource StrategyCardStyle}"
                                                Margin="8,0,8,8"
                                                MouseLeftButtonDown="StrategyFSS2_Click">
                                            <StackPanel>
                                                <TextBlock Text="FSS-2"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="Verify"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,2" />
                                                <TextBlock Text="~105% overhead"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- FSS-2R -->
                                        <Border x:Name="StrategyFSS2R"
                                                Style="{StaticResource StrategyCardStyle}"
                                                Margin="8,0,8,8"
                                                MouseLeftButtonDown="StrategyFSS2R_Click">
                                            <StackPanel>
                                                <TextBlock Text="FSS-2R"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="Diagnose"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,2" />
                                                <TextBlock Text="~100% overhead"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- FSS-3 -->
                                        <Border x:Name="StrategyFSS3"
                                                Style="{StaticResource StrategyCardStyle}"
                                                Margin="8,0,0,8"
                                                MouseLeftButtonDown="StrategyFSS3_Click">
                                            <StackPanel>
                                                <TextBlock Text="FSS-3"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="Reed-Solomon"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,2" />
                                                <TextBlock Text="~33% overhead"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- FSS-5 -->
                                        <Border x:Name="StrategyFSS5"
                                                Style="{StaticResource StrategyCardStyle}"
                                                Margin="0,8,8,0"
                                                MouseLeftButtonDown="StrategyFSS5_Click">
                                            <StackPanel>
                                                <TextBlock Text="FSS-5"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="Cross Recovery"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,2" />
                                                <TextBlock Text="~200% overhead"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- FSS-5+ -->
                                        <Border x:Name="StrategyFSS5P"
                                                Style="{StaticResource StrategyCardStyle}"
                                                Margin="8,8,8,0"
                                                MouseLeftButtonDown="StrategyFSS5P_Click">
                                            <StackPanel>
                                                <TextBlock Text="FSS-5+"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="Seed Recovery"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,2" />
                                                <TextBlock Text="~529% overhead"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- FSS-6 -->
                                        <Border x:Name="StrategyFSS6"
                                                Style="{StaticResource StrategyCardStyle}"
                                                Margin="8,8,8,0"
                                                MouseLeftButtonDown="StrategyFSS6_Click">
                                            <StackPanel>
                                                <TextBlock Text="FSS-6"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="ETN Verify"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,2" />
                                                <TextBlock Text="~32% overhead"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <!-- FSS-6+ -->
                                        <Border x:Name="StrategyFSS6P"
                                                Style="{StaticResource StrategyCardStyle}"
                                                Margin="8,8,0,0"
                                                IsEnabled="False"
                                                Opacity="0.3"
                                                MouseLeftButtonDown="StrategyFSS6P_Click">
                                            <StackPanel>
                                                <TextBlock Text="FSS-6+"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="ETN + ECCR"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,2" />
                                                <TextBlock Text="~35% overhead"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- Encryption Key -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Encryption Key"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,12" />
                                    <PasswordBox x:Name="EncryptKeyBox"
                                                 Height="36"
                                                 Background="{StaticResource BackgroundBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}"
                                                 BorderThickness="1"
                                                 Padding="10,0"
                                                 FontSize="13"
                                                 VerticalContentAlignment="Center"
                                                 PasswordChar="●" />
                                </StackPanel>
                            </Border>

                            <!-- Options -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0"
                                                Margin="0,0,8,0">
                                        <TextBlock Text="Fragment Size"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,0,6" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="FragmentSizeMB"
                                                     Style="{StaticResource TextBoxStyle}"
                                                     Text="1" />
                                            <TextBlock Grid.Column="1"
                                                       Text="MB"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1"
                                                Margin="8,0,0,0">
                                        <TextBlock Text="Output Path"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,0,6" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="EncryptOutputPath"
                                                      Style="{StaticResource TextBoxStyle}"
                                                      Text="{Binding OutputPath, FallbackValue='./backup'}"
                                                      IsReadOnly="True" />
                                            <Button Grid.Column="1"
                                                    Content="..."
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="12,8"
                                                    Margin="8,0,0,0"
                                                    Click="EncryptOutputBrowse_Click" />
                                        </Grid>
                                    </StackPanel>

                                    <!-- Fragment Preview -->
                                    <Border x:Name="EncryptFragmentPreviewCard"
                                            Grid.Row="1" Grid.ColumnSpan="2"
                                            Style="{StaticResource CardStyle}"
                                            Margin="0,12,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,12">
                                                <TextBlock Text="Fragment Preview"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock x:Name="EncryptFragmentSummary"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="12,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <!-- Legend -->
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,12">
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,0,16,0">
                                                    <Ellipse Width="8"
                                                             Height="8"
                                                             Fill="{StaticResource SurfaceHighlightBrush}"
                                                             Margin="0,0,4,0"
                                                             VerticalAlignment="Center" />
                                                    <TextBlock Text="Fragment"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Rectangle Width="8"
                                                               Height="8"
                                                               Fill="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,0,4,0"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="Per fragment size"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Fragment Grid -->
                                            <ItemsControl x:Name="EncryptFragmentGrid">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="40"
                                                                Height="40"
                                                                CornerRadius="6"
                                                                Background="{StaticResource SurfaceHighlightBrush}"
                                                                BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="1"
                                                                Margin="0,0,6,6">
                                                            <TextBlock Text="{Binding Index}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                                                Margin="0,16,0,0">
                                        <TextBlock Text="Custom Name (optional)"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,0,6" />
                                        <TextBox x:Name="CustomNameBox"
                                                 Style="{StaticResource TextBoxStyle}"
                                                 ToolTip="Leave empty to use fingerprint. Only letters, numbers, underscores and hyphens allowed." />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Progress Section -->
                            <Border x:Name="EncryptProgressSection"
                                    Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" x:Name="EncryptStageText"
                                                   Text="{Binding StageText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                                        <TextBlock Grid.Column="1" x:Name="EncryptPercentText"
                                                   Text="{Binding PercentText}"
                                                   Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold" />
                                    </Grid>
                                    <ProgressBar x:Name="EncryptProgressBar"
                                                 Value="{Binding ProgressPercent}"
                                                 Height="6" Margin="0,10,0,10"
                                                 Background="{StaticResource SurfaceHighlightBrush}"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 BorderThickness="0" Minimum="0" Maximum="100" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" x:Name="EncryptSpeedText"
                                                   Text="{Binding SpeedText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                        <TextBlock Grid.Column="1" x:Name="EncryptEtaText"
                                                   Text="{Binding EtaText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Start Button -->
                            <Button x:Name="StartEncryptButton"
                                    Content="Start Encryption"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Height="48"
                                    FontSize="16"
                                    HorizontalAlignment="Stretch"
                                    Click="StartEncrypt_Click" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Drop Overlay -->
                    <Border x:Name="EncryptDropOverlay"
                            Background="#20FFFFFF"
                            Visibility="Collapsed">
                        <Border BorderBrush="#7C6BF2"
                                BorderThickness="2"
                                CornerRadius="12"
                                Margin="20">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="📁"
                                           FontSize="48"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16" />
                                <TextBlock Text="Drop files here to encrypt"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Multiple files will be packed into a ZIP"
                                           FontSize="13"
                                           Foreground="#E0E0E8"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>

                <!-- ============== DECRYPT PAGE ============== -->
                <Grid x:Name="DecryptPage"
                      Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Backup File Selection (index or fragment) -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Backup File"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,4" />
                                    <TextBlock x:Name="DecryptFileHint"
                                               Text="{Binding FileHint}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="DecryptIndexPath"
                                                  Style="{StaticResource TextBoxStyle}"
                                                  Text="{Binding IndexPathDisplay, FallbackValue='No file selected...'}"
                                                  IsReadOnly="True" />

                                        <Button Grid.Column="1"
                                                Content="Browse"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="DecryptBrowse_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Decryption Key -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Decryption Key"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,12" />
                                    <PasswordBox x:Name="DecryptKeyBox"
                                                 Height="36"
                                                 Background="{StaticResource BackgroundBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}"
                                                 BorderThickness="1"
                                                 Padding="10,0"
                                                 FontSize="13"
                                                 VerticalContentAlignment="Center"
                                                 PasswordChar="●"
                                                 PasswordChanged="DecryptKeyBox_PasswordChanged" />
                                </StackPanel>
                            </Border>

                            <!-- File Info (shown after selecting index) -->
                            <Border x:Name="DecryptFileInfoCard"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16"
                                    Visibility="{Binding ShowFileInfo, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="File Information"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,16" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                            <TextBlock Text="Original Filename"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2" />
                                            <TextBlock x:Name="InfoFileName"
                                                        Text="{Binding InfoFileName}"
                                                        FontSize="13"
                                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Original Size"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2" />
                                            <TextBlock x:Name="InfoFileSize"
                                                        Text="{Binding InfoFileSize}"
                                                        FontSize="13"
                                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                            <TextBlock Text="Strategy"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2" />
                                            <TextBlock x:Name="InfoStrategy"
                                                        Text="{Binding InfoStrategy}"
                                                        FontSize="13"
                                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Fragments"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2" />
                                            <TextBlock x:Name="InfoFragmentCount"
                                                        Text="{Binding InfoFragmentCount}"
                                                        FontSize="13"
                                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0">
                                            <TextBlock Text="Created"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2" />
                                            <TextBlock x:Name="InfoCreated"
                                                        Text="{Binding InfoCreated}"
                                                        FontSize="13"
                                                        Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="1">
                                            <TextBlock Text="Encryption"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2" />
                                            <TextBlock Text="AES-256-GCM"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Fragment Status (shown after selecting index) -->
                            <Border x:Name="DecryptFragmentStatusCard"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16"
                                    Visibility="{Binding ShowFragmentStatus, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,12">
                                        <TextBlock Text="Fragment Status"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock x:Name="FragmentStatusSummary"
                                                    Text="{Binding FragmentSummary}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Legend -->
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,16,0">
                                            <Ellipse Width="8"
                                                     Height="8"
                                                     Fill="{StaticResource SuccessBrush}"
                                                     Margin="0,0,4,0"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="Available"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,16,0">
                                            <Ellipse Width="8"
                                                     Height="8"
                                                     Fill="{StaticResource ErrorBrush}"
                                                     Margin="0,0,4,0"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="Missing"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8"
                                                     Height="8"
                                                     Fill="{StaticResource WarningBrush}"
                                                     Margin="0,0,4,0"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="Corrupted"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Fragment Grid -->
                                    <ItemsControl x:Name="FragmentGrid"
                                                  ItemsSource="{Binding FragmentItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="40"
                                                        Height="40"
                                                        CornerRadius="6"
                                                        Background="{Binding Brush}"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Margin="0,0,6,6">
                                                    <TextBlock Text="{Binding Index}"
                                                               FontSize="11"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Output Path -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Output Path"
                                               FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,6" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="DecryptOutputPath"
                                                  Style="{StaticResource TextBoxStyle}"
                                                  Text="{Binding OutputPath, FallbackValue='./restored'}"
                                                  IsReadOnly="True" />
                                        <Button Grid.Column="1"
                                                Content="Browse"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="DecryptOutputBrowse_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Progress Section -->
                            <Border x:Name="DecryptProgressSection"
                                    Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" x:Name="DecryptStageText"
                                                   Text="{Binding StageText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                                        <TextBlock Grid.Column="1" x:Name="DecryptPercentText"
                                                   Text="{Binding PercentText}"
                                                   Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold" />
                                    </Grid>
                                    <ProgressBar x:Name="DecryptProgressBar"
                                                 Value="{Binding ProgressPercent}"
                                                 Height="6" Margin="0,10,0,10"
                                                 Background="{StaticResource SurfaceHighlightBrush}"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 BorderThickness="0" Minimum="0" Maximum="100" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" x:Name="DecryptSpeedText"
                                                   Text="{Binding SpeedText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                        <TextBlock Grid.Column="1" x:Name="DecryptEtaText"
                                                   Text="{Binding EtaText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Start Button -->
                            <Button x:Name="StartDecryptButton"
                                    Content="Start Decryption"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Height="48"
                                    FontSize="16"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{Binding IsStartEnabled}"
                                    Click="StartDecrypt_Click" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ============== HISTORY PAGE ============== -->
                <Grid x:Name="HistoryPage"
                      Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Backup File Selection -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Backup File"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="Select .indrdrf (index) file to view version history"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="HistoryIndexPath"
                                                  Style="{StaticResource TextBoxStyle}"
                                                  Text="{Binding IndexPathDisplay, FallbackValue='No file selected...'}"
                                                  IsReadOnly="True" />

                                        <Button Grid.Column="1"
                                                Content="Browse"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="HistoryBrowseBackup_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Incremental Content -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Incremental Content (optional)"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="Select a new file to append as the next version"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,12" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="HistoryIncrementalPath"
                                                  Style="{StaticResource TextBoxStyle}"
                                                  Text="{Binding IncrementalDisplay, FallbackValue=''}"
                                                  IsReadOnly="True" />

                                        <Button Grid.Column="1"
                                                Content="Browse"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="HistoryBrowseIncremental_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Decryption Key -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Decryption Key"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,12" />
                                    <PasswordBox x:Name="HistoryKeyBox"
                                                  Height="36"
                                                  Background="{StaticResource BackgroundBrush}"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  BorderBrush="{StaticResource BorderBrush}"
                                                  BorderThickness="1"
                                                  Padding="10,0"
                                                  FontSize="13"
                                                  VerticalContentAlignment="Center"
                                                  PasswordChar="●"
                                                  PasswordChanged="HistoryKeyBox_PasswordChanged" />
                                </StackPanel>
                            </Border>

                            <!-- Commit Message (shown when incremental selected) -->
                            <Border x:Name="HistoryCommitCard"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16"
                                    Visibility="{Binding ShowIncrementalSection, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="Commit Message"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,12" />
                                    <TextBox x:Name="HistoryCommitBox"
                                              Style="{StaticResource TextBoxStyle}"
                                              Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                              Height="36"
                                              ToolTip="Describe what changed in this version" />
                                </StackPanel>
                            </Border>

                            <!-- Apply Button (shown when incremental selected) -->
                            <Button x:Name="HistoryApplyButton"
                                    Content="Apply Incremental Backup"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Height="48"
                                    FontSize="16"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,16"
                                    Visibility="{Binding ShowIncrementalSection, Converter={StaticResource BoolToVis}}"
                                    Click="HistoryApply_Click" />

                            <!-- Version History List -->
                            <Border x:Name="HistoryVersionCard"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16"
                                    Visibility="{Binding ShowVersionHistory, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,12">
                                        <TextBlock Text="Version History"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock x:Name="HistoryCountText"
                                                    Text="{Binding StatusText}"
                                                    FontSize="12"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Version List -->
                                    <ListView x:Name="HistoryVersionList"
                                              ItemsSource="{Binding Versions}"
                                              SelectedItem="{Binding SelectedItem}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Margin="0,0,0,12"
                                              MaxHeight="200"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Padding" Value="8,6" />
                                                <Setter Property="Cursor" Value="Hand" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceHighlightBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceHighlightBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40" />
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="8"
                                                             Height="8"
                                                             Fill="{StaticResource AccentBrush}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0" />
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Version, StringFormat='v#{0}'}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Timestamp}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Message}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>

                            <!-- Diff Panel (placeholder) -->
                            <Border x:Name="HistoryDiffCard"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0,0,0,16"
                                    Visibility="{Binding ShowDiffPanel, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="Diff Details"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,12" />

                                    <Border Background="{StaticResource BackgroundBrush}"
                                            CornerRadius="6"
                                            Padding="0"
                                            MaxHeight="500">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding DiffLines}"
                                                          Background="Transparent"
                                                          BorderThickness="0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Text}"
                                                                   Foreground="{Binding Foreground}"
                                                                   Background="{Binding Background}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{Binding FontSize}"
                                                                   FontWeight="{Binding FontWeight}"
                                                                   Padding="12,1"
                                                                   TextWrapping="NoWrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
