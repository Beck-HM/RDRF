<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Color x:Key="BackgroundColor">#FF1E1E2E</Color>
    <Color x:Key="SurfaceColor">#FF2A2A3C</Color>
    <Color x:Key="SurfaceHighlightColor">#FF35354A</Color>
    <Color x:Key="BorderColor">#FF3D3D56</Color>
    <Color x:Key="TextPrimaryColor">#FFE0E0E8</Color>
    <Color x:Key="TextSecondaryColor">#FF9090A8</Color>
    <Color x:Key="AccentColor">#FF7C6BF2</Color>
    <Color x:Key="AccentHoverColor">#FF9588F5</Color>
    <Color x:Key="SuccessColor">#FF50FA7B</Color>
    <Color x:Key="WarningColor">#FFFFB86C</Color>
    <Color x:Key="ErrorColor">#FFFF5555</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceHighlightBrush" Color="{StaticResource SurfaceHighlightColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
</ResourceDictionary>
